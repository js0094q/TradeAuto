APP_ENV=test
TRADING_MODE=paper
LIVE_TRADING_ENABLED=false
HOST=127.0.0.1
PORT=8000
POSTGRES_URL=postgresql://trader_app:CHANGE_ME@127.0.0.1:5432/trading_system_test
REDIS_URL=redis://127.0.0.1:6379/1
ALPACA_API_KEY=CHANGE_ME
ALPACA_API_SECRET=CHANGE_ME
ALPACA_SECRET_KEY=CHANGE_ME
ALPACA_LIVE_TRADE=false
ALPACA_CONFIG_DIR=/opt/trading-system/shared/alpaca
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_FEED=iex
ALPACA_CLI_ENABLED=true
ALPACA_CLI_PROFILE=paper
TELEGRAM_BOT_TOKEN=example_test_bot_token
TELEGRAM_ALLOWED_CHAT_IDS=123456
TELEGRAM_ADMIN_CHAT_IDS=123456
ADMIN_TOKEN=example_test_admin_token
DASHBOARD_TOKEN=example_test_dashboard_token
JWT_SIGNING_KEY=example_test_jwt_key
LOG_LEVEL=INFO
LOG_DIR=/tmp/trading-system-test/logs
KILL_SWITCH_ENABLED=false
KILL_SWITCH_FILE=/opt/trading-system/shared/state/kill_switch.enabled
MAX_TRADES_PER_DAY=3
MAX_OPEN_POSITIONS=3
MAX_ORDER_NOTIONAL_USD=25
MAX_POSITION_NOTIONAL_USD=50
MAX_DAILY_LOSS_USD=25
MAX_TOTAL_DRAWDOWN_USD=100
MAX_ACCOUNT_RISK_PCT=1.0
REQUIRE_LIMIT_ORDERS=true
ALLOW_MARKET_ORDERS=false
ALLOW_SHORT_SELLING=false
ALLOW_OPTIONS_TRADING=false
ALLOW_CRYPTO_TRADING=false
HEALTH_CHECKS_ENABLED=true
