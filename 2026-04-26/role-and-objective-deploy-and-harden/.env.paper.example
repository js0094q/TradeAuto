APP_ENV=paper
TRADING_MODE=paper
LIVE_TRADING_ENABLED=false
HOST=127.0.0.1
PORT=8000
POSTGRES_URL=postgresql://trader_app:CHANGE_ME@127.0.0.1:5432/trading_system_paper
REDIS_URL=redis://127.0.0.1:6379/1
ALPACA_API_KEY=CHANGE_ME
ALPACA_API_SECRET=CHANGE_ME
ALPACA_SECRET_KEY=CHANGE_ME
ALPACA_LIVE_TRADE=false
ALPACA_CONFIG_DIR=/opt/trading-system/shared/alpaca
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_FEED=iex
ALPACA_CLI_ENABLED=true
ALPACA_CLI_PROFILE=paper
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_ALLOWED_CHAT_IDS=CHANGE_ME
TELEGRAM_ADMIN_CHAT_IDS=CHANGE_ME
ADMIN_TOKEN=CHANGE_ME
DASHBOARD_TOKEN=CHANGE_ME
JWT_SIGNING_KEY=CHANGE_ME
LOG_LEVEL=INFO
LOG_DIR=/opt/trading-system/shared/logs
KILL_SWITCH_ENABLED=false
KILL_SWITCH_FILE=/opt/trading-system/shared/state/kill_switch.enabled
MAX_TRADES_PER_DAY=10
MAX_OPEN_POSITIONS=6
MAX_ORDER_NOTIONAL_USD=25000
MAX_POSITION_NOTIONAL_USD=30000
MAX_DAILY_LOSS_USD=2500
MAX_TOTAL_DRAWDOWN_USD=10000
MAX_ACCOUNT_RISK_PCT=1.0
REQUIRE_LIMIT_ORDERS=true
ALLOW_MARKET_ORDERS=false
ALLOW_SHORT_SELLING=false
ALLOW_OPTIONS_TRADING=false
ALLOW_CRYPTO_TRADING=false
PAPER_ENTRY_EXECUTION_ENABLED=true
PAPER_ENTRY_BANKROLL_USD=100000
PAPER_ENTRY_MAX_NOTIONAL_USD=25000
PAPER_ENTRY_UPSIZE_THRESHOLD_PCT=0.95
PAPER_ENTRY_LIMIT_BUFFER_BPS=100
PAPER_ENTRY_ORDER_TYPE=limit
HEALTH_CHECKS_ENABLED=true
