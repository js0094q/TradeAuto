TRADING_API_BASE_URL=https://jlsprojects.com
# Optional: use when DNS for TRADING_API_BASE_URL cannot point directly at the VPS.
# TRADING_API_BASE_URL=https://45.142.140.188
# TRADING_API_HOST_HEADER=jlsprojects.com
# TRADING_API_TLS_SERVERNAME=jlsprojects.com
TRADING_API_ADMIN_TOKEN=replace_with_vps_admin_token
TRADING_API_BASIC_AUTH=operator:replace_with_nginx_operator_password
DASHBOARD_ACCESS_TOKEN=replace_with_dashboard_login_token
DASHBOARD_SESSION_SECRET=replace_with_random_cookie_secret
DASHBOARD_ALLOW_CONTROL_ACTIONS=false
